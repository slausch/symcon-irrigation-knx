{
  "elements": [
    {
      "type": "RowLayout",
      "items": [
        { "type": "Button", "caption": "README", "onClick": "echo 'https://github.com/slausch/symcon-irrigation-knx#readme';", "link": true },
        { "type": "CheckBox", "name": "Enabled", "caption": "Module enabled" },
        { "type": "CheckBox", "name": "AutomaticDefault", "caption": "Automatic enabled initially" },
        { "type": "CheckBox", "name": "LogOperations", "caption": "Log operations" }
      ]
    },
    {
      "type": "RowLayout",
      "items": [
        { "type": "CheckBox", "name": "Simulation", "caption": "Simulation (no hardware writes)" },
        { "type": "NumberSpinner", "name": "SimulationRuntimeMinutes", "caption": "Test runtime (simulation only)", "minimum": 1, "maximum": 240, "suffix": " min" }
      ]
    },
    { "type": "Label", "label": "Before first use, enable simulation and monitor state, current zone, remaining time and requested outputs in the object tree. At least one zone needs a name, an enabled automatic-program checkbox and one Boolean valve variable." },
    { "type": "Label", "label": "Applying any configuration change safely stops a running irrigation program." },
    {
      "type": "ExpansionPanel",
      "caption": "Pump and main valve",
      "expanded": true,
      "items": [
        { "type": "Label", "label": "Both outputs are optional. The program also works with only a pump, only a main valve or neither, for example on a public water supply." },
        { "type": "Label", "label": "Multiple instances are supported, but the same pump or valve output must not be controlled by more than one instance." },
        {
          "type": "List",
          "name": "MainValves",
          "caption": "Slot 1 is the irrigation pump, slot 2 is the main valve; feedback is optional",
          "rowCount": 2,
          "add": false,
          "delete": false,
          "columns": [
            { "caption": "Enabled", "name": "Enabled", "width": "60px", "add": false, "edit": { "type": "CheckBox" } },
            { "caption": "Name", "name": "Name", "width": "140px", "add": "", "edit": { "type": "ValidationTextBox" } },
            { "caption": "Boolean output variable", "name": "VariableID", "width": "300px", "add": 0, "edit": { "type": "SelectVariable", "validVariableTypes": [0], "requiredAction": 1 } },
            { "caption": "Boolean feedback", "name": "FeedbackID", "width": "300px", "add": 0, "edit": { "type": "SelectVariable", "validVariableTypes": [0] } },
            { "caption": "Invert feedback", "name": "FeedbackInverted", "width": "105px", "add": false, "edit": { "type": "CheckBox" } }
          ],
          "values": [
            { "Enabled": false, "Name": "Irrigation pump", "VariableID": 0, "FeedbackID": 0, "FeedbackInverted": false },
            { "Enabled": false, "Name": "Main valve", "VariableID": 0, "FeedbackID": 0, "FeedbackInverted": false }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Zones",
      "expanded": true,
      "items": [
        { "type": "Label", "label": "Automatic program selects whether a zone participates. Irrigation mode is a variable: 0 disables watering, 1 waters zones individually (default), and 2 waters equal group numbers together in ascending group order. Each grouped zone retains its own runtime." },
        {
          "type": "List",
          "name": "Zones",
          "caption": "Ten zones with up to two valves each; optionally grouped",
          "rowCount": 10,
          "add": false,
          "delete": false,
          "columns": [
            { "caption": "Automatic program", "name": "Enabled", "width": "95px", "add": false, "edit": { "type": "CheckBox" } },
            { "caption": "Name", "name": "Name", "width": "120px", "add": "", "edit": { "type": "ValidationTextBox" } },
            { "caption": "Valve 1", "name": "Valve1ID", "width": "145px", "add": 0, "edit": { "type": "SelectVariable", "validVariableTypes": [0], "requiredAction": 1 } },
            { "caption": "Valve 2", "name": "Valve2ID", "width": "135px", "add": 0, "edit": { "type": "SelectVariable", "validVariableTypes": [0], "requiredAction": 1 } },
            { "caption": "Feedback 1", "name": "Feedback1ID", "width": "155px", "add": 0, "edit": { "type": "SelectVariable", "validVariableTypes": [0] } },
            { "caption": "Feedback 2", "name": "Feedback2ID", "width": "135px", "add": 0, "edit": { "type": "SelectVariable", "validVariableTypes": [0] } },
            { "caption": "Inv. FB 1", "name": "Feedback1Inverted", "width": "55px", "add": false, "edit": { "type": "CheckBox" } },
            { "caption": "Inv. FB 2", "name": "Feedback2Inverted", "width": "55px", "add": false, "edit": { "type": "CheckBox" } },
            { "caption": "Group", "name": "Group", "width": "55px", "add": 1, "edit": { "type": "NumberSpinner", "minimum": 1, "maximum": 100 } },
            { "caption": "Responds to rain", "name": "RainSensitive", "width": "65px", "add": true, "edit": { "type": "CheckBox" } },
            { "caption": "Runtime", "name": "RuntimeMinutes", "width": "70px", "add": 10, "edit": { "type": "NumberSpinner", "minimum": 1, "maximum": 240, "suffix": " min" } }
          ],
          "values": [
            { "Enabled": false, "Name": "Zone 1", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 1, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 2", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 2, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 3", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 3, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 4", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 4, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 5", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 5, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 6", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 6, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 7", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 7, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 8", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 8, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 9", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 9, "RainSensitive": true, "RuntimeMinutes": 10 },
            { "Enabled": false, "Name": "Zone 10", "Valve1ID": 0, "Valve2ID": 0, "Feedback1ID": 0, "Feedback2ID": 0, "Feedback1Inverted": false, "Feedback2Inverted": false, "Group": 10, "RainSensitive": true, "RuntimeMinutes": 10 }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Schedule",
      "items": [
        {
          "type": "RowLayout",
          "items": [
            { "type": "ValidationTextBox", "name": "StartTime", "caption": "Start time (HH:MM)" },
            { "type": "NumberSpinner", "name": "IntervalDays", "caption": "Every n days", "minimum": 1, "maximum": 365 },
            { "type": "ValidationTextBox", "name": "IntervalAnchor", "caption": "Anchor date (YYYY-MM-DD)" }
          ]
        },
        { "type": "Label", "label": "Interval days are calculated from the anchor date. If an interval day falls on a disabled weekday, that run is postponed to the next enabled weekday. At most one automatic run starts per calendar day." },
        {
          "type": "RowLayout",
          "items": [
            { "type": "CheckBox", "name": "Monday", "caption": "Monday" },
            { "type": "CheckBox", "name": "Tuesday", "caption": "Tuesday" },
            { "type": "CheckBox", "name": "Wednesday", "caption": "Wednesday" },
            { "type": "CheckBox", "name": "Thursday", "caption": "Thursday" },
            { "type": "CheckBox", "name": "Friday", "caption": "Friday" },
            { "type": "CheckBox", "name": "Saturday", "caption": "Saturday" },
            { "type": "CheckBox", "name": "Sunday", "caption": "Sunday" }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Sensors and safety",
      "items": [
        {
          "type": "RowLayout",
          "items": [
            { "type": "SelectVariable", "name": "RainSensorID", "caption": "Boolean rain sensor", "validVariableTypes": [0] },
            { "type": "CheckBox", "name": "RainActiveValue", "caption": "Rain active value" },
            { "type": "SelectVariable", "name": "SoilMoistureSensorID", "caption": "Soil moisture", "validVariableTypes": [1, 2] },
            { "type": "NumberSpinner", "name": "SoilMoistureLimit", "caption": "Soil moisture limit", "digits": 2 },
            { "type": "CheckBox", "name": "SoilBlocksAboveLimit", "caption": "Block at/above limit" }
          ]
        },
        { "type": "Label", "label": "The rain sensor is active when its Boolean value equals Rain active value. Only zones with Responds to rain enabled are skipped. If such a zone is running when rain starts, it closes and the next unaffected zone starts after the configured zone delay." },
        { "type": "Label", "label": "Soil moisture is numeric. With Block at/above limit enabled, values greater than or equal to the limit block watering; when disabled, values less than or equal to the limit block it. Soil moisture remains a central block and safely stops the complete program." },
        {
          "type": "RowLayout",
          "items": [
            { "type": "NumberSpinner", "name": "PumpLeadSeconds", "caption": "Pump start delay", "minimum": 0, "maximum": 300, "suffix": " s" },
            { "type": "NumberSpinner", "name": "InterZoneSeconds", "caption": "Zone and main-valve delay", "minimum": 0, "maximum": 300, "suffix": " s" },
            { "type": "NumberSpinner", "name": "FeedbackTimeoutSeconds", "caption": "Feedback timeout", "minimum": 1, "maximum": 300, "suffix": " s" },
            { "type": "CheckBox", "name": "MonitorClosedFeedback", "caption": "Monitor OFF feedback" },
            { "type": "NumberSpinner", "name": "MaximumProgramMinutes", "caption": "Maximum program runtime", "minimum": 1, "maximum": 1440, "suffix": " min" }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Credit and license",
      "items": [
        { "type": "Label", "label": "This module is a small thank-you from Sepp Lausch for all the many modules I have happily used over the years." },
        { "type": "Label", "label": "Here is my first module (complaints to Codex)." },
        { "type": "Label", "label": "I may not be able to provide support or handle change requests; it is already a small miracle that I managed this. So far it has worked in several (KNX) installations." },
        { "type": "Label", "label": "Sepp Lausch, Lausch SmarthomeCoach, Wangari Smart Integration LTD" },
        { "type": "Label", "label": "License: Zero-Clause BSD (0BSD) – free use, modification and distribution without attribution requirement; provided without warranty." }
      ]
    }
  ],
  "actions": [
    { "type": "Label", "label": "Use simulation for initial commissioning. Skip acts on the complete current or next group in group mode. OFF feedback monitoring is disabled by default because missing KNX OFF telegrams otherwise block the sequence; ON feedback remains monitored." },
    {
      "type": "RowLayout",
      "items": [
        { "type": "Button", "caption": "No watering", "onClick": "IRRKNX_SetIrrigationMode($id, 0);" },
        { "type": "Button", "caption": "Water zones individually", "onClick": "IRRKNX_SetIrrigationMode($id, 1);" },
        { "type": "Button", "caption": "Water groups", "onClick": "IRRKNX_SetIrrigationMode($id, 2);" }
      ]
    },
    {
      "type": "RowLayout",
      "items": [
        { "type": "Button", "caption": "Start program", "onClick": "IRRKNX_StartProgram($id, true);" },
        { "type": "Button", "caption": "Pause / Resume", "onClick": "IRRKNX_TogglePause($id);" },
        { "type": "Button", "caption": "Skip zone", "onClick": "IRRKNX_SkipCurrentZone($id);" },
        { "type": "Button", "caption": "Stop", "confirm": "Stop the irrigation program? A stopped program cannot be resumed.", "onClick": "IRRKNX_Stop($id);" },
        { "type": "Button", "caption": "Safety stop", "confirm": "Close all configured outputs and record a safety fault now?", "onClick": "IRRKNX_EmergencyStop($id);" }
      ]
    }
  ],
  "status": [
    { "code": 200, "icon": "error", "caption": "Invalid configuration" }
  ]
}
